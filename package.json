{
  "name": "ghin",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build:frontend": "turbo build --filter=frontend",
    "start:frontend": "turbo start --filter=frontend",
    "dev:frontend": "turbo dev --filter=frontend",
    "lint": "turbo lint",
    "test": "turbo test",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "checks": "turbo run typecheck build lint test format:check",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:push": "pnpm --filter @repo/database db:push",
    "db:studio": "pnpm --filter @repo/database db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/engines", "better-sqlite3", "prisma"]
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "turbo": "2.9.0"
  }
}
